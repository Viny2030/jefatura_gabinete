# Portal Anticorrupción JGM — variables de entorno
# Copiá este archivo a .env y completá los valores

# Base de datos PostgreSQL (Railway la inyecta automáticamente en producción)
DATABASE_URL=postgresql://usuario:password@localhost:5432/jefatura_gabinete

# Token para el endpoint /api/refresh (elegí uno seguro)
REFRESH_TOKEN=cambia_esto_por_un_token_secreto

# Notificaciones por email (opcional)
MAIL_USER=tu_email@gmail.com
MAIL_PASS=tu_app_password_gmail

# Railway Database (para los workflows de GitHub Actions)
RAILWAY_DATABASE_URL=postgresql://usuario:password@host.railway.app:5432/railway